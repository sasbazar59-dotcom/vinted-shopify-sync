# --- VINTED PRO ---
# Format: access_key,signing_key (séparés par une virgule, sans espace)
# Trouve ces valeurs dans ton portail Vinted Pro > Intégrations
VINTED_ACCESS_TOKEN=ta_access_key,ta_signing_key

# --- SHOPIFY ---
# Domaine de ta boutique (sans https://)
SHOPIFY_STORE_DOMAIN=ta-boutique.myshopify.com

# Token d'accès Admin Shopify
# Créer dans : Admin Shopify > Paramètres > Applications > Développer des apps
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# --- VERCEL ---
# URL de ton projet Vercel après déploiement (sans / à la fin)
VERCEL_URL=https://ton-projet.vercel.app

# Mot de passe secret pour sécuriser tes webhooks (invente n'importe quoi)
WEBHOOK_SECRET=un_mot_de_passe_secret_inventé_par_toi
